[submodule ".config/alacritty/alacritty-theme"]
	path = .config/alacritty/alacritty-theme
	url = https://github.com/alacritty/alacritty-theme.git
[submodule ".config/nvim/pack/nvim/start/nvim-lspconfig"]
	path = .config/nvim/pack/nvim/start/nvim-lspconfig
	url = https://github.com/neovim/nvim-lspconfig.git
[submodule "bash-it"]
	path = bash-it
	url = git@github.com:nbelanger99/bash-it.git
[submodule ".config/nvim/pack/nvim/start/nvim-treesitter"]
	path = .config/nvim/pack/nvim/start/nvim-treesitter
	url = https://github.com/nvim-treesitter/nvim-treesitter.git
[submodule ".config/nvim/pack/nvim/start/nvim"]
	path = .config/nvim/pack/nvim/start/nvim
	url = https://github.com/catppuccin/nvim.git
[submodule ".config/tmux/plugins/tmux"]
	path = .config/tmux/plugins/tmux
	url = https://github.com/catppuccin/tmux.git
[submodule ".fzf"]
  path = .fzf
  url = https://github.com/junegunn/fzf.git
